{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "buildshell",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "gcc -g -D_POSIX_C_SOURCE=200809L -Iinclude $(find src -name '*.c') -o out/main -lreadline"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "run shell project",
      "type": "shell",
      "command": "./src/main",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "build shell project",
      "problemMatcher": []
    }
  ]
}